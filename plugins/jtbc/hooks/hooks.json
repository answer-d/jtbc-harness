{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/team_guard.py",
            "description": "teams有効時にjtbc役職の一発実行spawnを阻止し常駐teammateへ誘導"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/memory_grant.py",
            "description": ".jtbc/memory/への書込みを自動承認(settings.json不要)。他役職メモはdeny"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/phase_guard.py",
            "description": "現フェーズで編集禁止のパスへのEdit/Writeを阻止"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/role_guard.py",
            "description": "現在のagent役職に許可されたパス以外への書込みを阻止"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ringi_guard.py",
            "description": "未承認の変更管理票が必要な対象への編集を阻止"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ringi_consistency.py",
            "description": "変更管理票のtypeが改訂対象を覆っているかを起票時に検証"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/incident_guard.py",
            "description": "緊急対応中(active_incidents非空)に前進系ガバナンス文書の編集を阻止"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/state_guard.py",
            "description": "フェーズ移行(state.json#phaseの変更)をPMO役職に限定"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/memory_timeline.py",
            "description": "state.json#phase変更時に.jtbc/memory/_timeline.mdへ決定論的に追記"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/memory_reminder.py",
            "description": "知識生産役職がメモ未記録のとき随時記録を促す(通知のみ)"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/superior_visit.py",
            "description": "上長視察(社長/部長)の確率的発生"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/approval_sync_guard.py",
            "description": "gate記録に押印済みだがstate.json#approvals未転記の承認をリード/PMOへ通知"
          }
        ]
      }
    ]
  }
}
